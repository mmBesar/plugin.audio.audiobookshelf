<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <category id="server" label="30001">
        <group id="1" label="30010">
            <setting id="server_url" type="string" label="30011" help="30012">
                <level>0</level>
                <default>http://localhost:13378</default>
                <constraints>
                    <allowempty>false</allowempty>
                </constraints>
            </setting>
            <setting id="api_token" type="string" label="30013" help="30014" option="hidden">
                <level>0</level>
                <default></default>
                <constraints>
                    <allowempty>false</allowempty>
                </constraints>
            </setting>
            <setting id="test_connection" type="action" label="30015" help="30016" action="RunPlugin(plugin://plugin.audio.audiobookshelf/?action=test_connection)">
                <level>0</level>
            </setting>
        </group>
    </category>

    <category id="playback" label="30002">
        <group id="2" label="30020">
            <setting id="sync_interval" type="slider" label="30021" help="30022">
                <level>1</level>
                <default>30</default>
                <constraints>
                    <minimum>10</minimum>
                    <step>5</step>
                    <maximum>300</maximum>
                </constraints>
                <control type="slider" format="integer" suffix=" sec"/>
            </setting>
            <setting id="auto_resume" type="boolean" label="30023" help="30024">
                <level>0</level>
                <default>true</default>
            </setting>
            <setting id="mark_finished_threshold" type="slider" label="30025" help="30026">
                <level>1</level>
                <default>30</default>
                <constraints>
                    <minimum>10</minimum>
                    <step>5</step>
                    <maximum>120</maximum>
                </constraints>
                <control type="slider" format="integer" suffix=" sec"/>
            </setting>
        </group>
    </category>

    <category id="interface" label="30003">
        <group id="3" label="30030">
            <setting id="show_descriptions" type="boolean" label="30031" help="30032">
                <level>0</level>
                <default>true</default>
            </setting>
            <setting id="episodes_per_page" type="slider" label="30033" help="30034">
                <level>1</level>
                <default>50</default>
                <constraints>
                    <minimum>10</minimum>
                    <step>10</step>
                    <maximum>200</maximum>
                </constraints>
                <control type="slider" format="integer"/>
            </setting>
            <setting id="sort_episodes" type="select" label="30035" help="30036">
                <level>1</level>
                <default>0</default>
                <constraints>
                    <options>
                        <option label="30037">0</option>
                        <option label="30038">1</option>
                    </options>
                </constraints>
            </setting>
            <setting id="sort_newest_first" type="boolean" label="30039">
                <level>0</level>
                <default>true</default>
            </setting>
        </group>
    </category>
</settings>
