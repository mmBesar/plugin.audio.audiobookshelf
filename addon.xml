<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.audio.audiobookshelf" name="Audiobookshelf" version="1.0.0" provider-name="mBesar">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
        <import addon="script.module.inputstreamhelper" version="0.5.2" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>audio</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Audiobookshelf Podcast Player</summary>
        <description lang="en_GB">Stream podcasts from your self-hosted Audiobookshelf server with progress sync. Listen to your podcasts and keep your progress synchronized across all devices.</description>
        <disclaimer lang="en_GB">This add-on requires a self-hosted Audiobookshelf server</disclaimer>
        <language>en</language>
        <platform>all</platform>
        <license>MIT</license>
        <forum></forum>
        <website>https://github.com/mmBesar/plugin.audio.audiobookshelf</website>
        <email></email>
        <source>https://github.com/mmBesar/plugin.audio.audiobookshelf</source>
        <news>v1.0.0 - Initial release with podcast support and progress sync</news>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
